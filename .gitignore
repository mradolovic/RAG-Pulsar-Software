# ── Compiled binaries ────────────────────────────────────────────────────────
*.out
*.exe

# ── Raw / processed observation data ─────────────────────────────────────────
*.bin

# ── Plot output ───────────────────────────────────────────────────────────────
*.png

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── pulsar_det_an result text files ──────────────────────────────────────────
# Ignore everything in results/ except the blank template files
results/
!results/
!results/pulsar_det_an_results/
!results/pulsar_det_an_results/Blankf.txt
!results/pulsar_det_an_results/Blanks.txt
!results/pul_plot_results/

# ── Raw observation data folder ───────────────────────────────────────────────
data/

# ── RTL/bin compiled outputs and blank templates ─────────────────────────────
RTL/bin/*.out
RTL/bin/*.exe
# Keep blank templates in RTL/bin
!RTL/bin/Blankf.txt
!RTL/bin/Blanks.txt
