# ── Compiled binaries ─────────────────────────────────────────────────────────
*.out
*.exe
*.o
# ── Raw / processed observation data ─────────────────────────────────────────
*.bin

# ── Plot output ───────────────────────────────────────────────────────────────
*.png

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── Raw observation data folder ───────────────────────────────────────────────
data/

# ── pulsar_det_an result text files ──────────────────────────────────────────
results/pulsar_det_an_results/*.txt
results/pul_plot_results/

# Keep blank templates in results
!results/pulsar_det_an_results/Blankf.txt
!results/pulsar_det_an_results/Blanks.txt

# ── RTL/bin ───────────────────────────────────────────────────────────────────
# *.out and *.exe are already caught above, so just explicitly keep the Blanks
RTL/bin/*.out
RTL/bin/*.exe
